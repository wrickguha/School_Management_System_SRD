<IfModule mod_rewrite.c>
    RewriteEngine on
    
    # Redirect all incoming traffic to the public/ folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
    
    # Security: Block direct access to sensitive system files and folders
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^artisan$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^package\.json$ - [F,L]
    RewriteRule ^phpunit\.xml$ - [F,L]
    RewriteRule ^(app|bootstrap|config|database|resources|routes|storage|tests|vendor)(/|$) - [F,L]
</IfModule>
